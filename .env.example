# .env.example
# Copy this file to `.env` and fill in your real keys.
# `.env` is gitignored — NEVER commit real keys. This template is safe to commit.

# ---- LLM providers (you have all three) ----
# Used by the strategy-pattern LLM layer in pipelines/strategy/.
OPENAI_API_KEY=sk-...your-openai-key...
ANTHROPIC_API_KEY=sk-ant-...your-anthropic-key...
OPENROUTER_API_KEY=sk-or-...your-openrouter-key...

# ---- Self-hosted MCP server (local, what you build in Phase 1) ----
# The URL your LangGraph / OpenAI Agents SDK pipelines connect to.
# Default for a locally-served FastMCP streamable-HTTP server:
MCP_SERVER_URL=http://localhost:8000/mcp
# Optional: if you add a dummy bearer-token check to your server to exercise the
# auth-header code path (mirroring Kapa's auth), set it here. Leave blank if your
# local server is unauthenticated.
MCP_SERVER_AUTH_TOKEN=

# ---- "Swap in real Kapa" (for LATER, once you have access) ----
# When you get a Kapa trial / demo / open-source-program account, point the pipelines
# at the real hosted MCP server by setting these instead of MCP_SERVER_URL above.
# Verify the exact variable names/contract against current Kapa docs before relying on them:
#   https://docs.kapa.ai/integrations/mcp/overview
# KAPA_MCP_SERVER_URL=https://<your-project>.mcp.kapa.ai
# KAPA_API_KEY=...your-kapa-key...
# PRODUCT_NAME=fastapi    # determines the tool name: search_<PRODUCT_NAME>_knowledge_sources

# ---- Model selection (optional convenience overrides) ----
# The specific model IDs used as the "frontier" and "free" models under test, and the
# cheap model used for claim decomposition. Pin these so runs are reproducible.
FRONTIER_MODEL=
FREE_MODEL=
DECOMPOSITION_MODEL=

# ---- Misc ----
# Where to cache LLM/NLI outputs (gitignored). Helps with re-runs and flaky free models.
CACHE_DIR=.cache
